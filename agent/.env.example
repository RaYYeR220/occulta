# Copy to .env and fill in. Never commit .env — it is gitignored by the repo root's .gitignore
# (the bare `.env` / `.env.*` patterns there apply at any depth, this file included).

# The runtime's signing key. For this deployment it is the same operator key that plays
# depositor/strategist/agent-runtime in scripts/demo.ts (see deployments/sepolia.json's
# `agentRuntime`) — StrategyRegistry names this address as agent 0's authorized runtime, and
# OccultaVault's owner() is the same address, so it is the only key that can approve deposits,
# submit intents, close epochs, and settle.
RUNTIME_PRIVATE_KEY=0x<your-runtime-private-key>

# Optional — falls back to a public Sepolia RPC if unset.
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/<your-key>

# Safety switch. true (default): plans every cycle and logs exactly what it would send, without
# broadcasting a single state-changing transaction. Set to false only when you intend to spend
# real gas on live Sepolia.
DRY_RUN=true

# Run exactly one tick (deposit sweep + one settlement-cycle decision) and exit, instead of
# looping forever. Useful for capturing a clean transcript or for external cron-style scheduling.
RUN_ONCE=false

# --- Loop timing ---
POLL_INTERVAL_MS=15000
EPOCH_CADENCE_MS=300000
CONFIRMATION_DEPTH=2
MAX_BACKOFF_MS=120000
# DepositRequest log-scan window. Kept small by default because many RPC providers cap
# eth_getLogs to a tight block range on their free tier (Alchemy's free tier: 10 blocks/call) —
# raise both if your provider allows a wider range.
DEPOSIT_SCAN_LOOKBACK_BLOCKS=300
DEPOSIT_LOG_CHUNK_BLOCKS=10

# --- Strategy / execution bounds ---
SLIPPAGE_BPS=300
MAX_INTENT_USDC=20
MAX_INTENT_WETH=0.002
MIN_TRADE_USDC=1
MIN_TRADE_WETH=0.0002
EXECUTOR_USDC_BUFFER=5

# Agent id in StrategyRegistry. Defaults to the value in deployments/sepolia.json (agent 0) if unset.
AGENT_ID=
